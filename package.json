{
  "name": "promptpilot",
  "version": "0.1.0",
  "description": "AI-powered software planning pipeline — go from idea to complete specification suite in minutes",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/promptpilot/promptpilot"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "bin": {
    "promptpilot": "./bin/promptpilot.js"
  },
  "scripts": {
    "build": "turbo run build",
    "build:tsc": "tsc -b",
    "clean": "rimraf packages/*/dist packages/*/*.tsbuildinfo apps/*/dist apps/*/*.tsbuildinfo node_modules/.cache/turbo",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@promptpilot/api",
    "dev:frontend": "turbo run dev --filter=@promptpilot/frontend",
    "dev:backend": "turbo run dev --filter=@promptpilot/backend",
    "start:api": "node apps/api/dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "turbo run lint",
    "lint:fix": "eslint packages/*/src/**/*.ts apps/*/src/**/*.ts --fix",
    "format": "node ./scripts/prettier-check.js",
    "format:fix": "node ./scripts/prettier-fix.js",
    "typecheck": "turbo run typecheck",
    "ci": "pnpm run lint && pnpm run format && pnpm run build && pnpm run test",
    "audit": "pnpm audit --audit-level=high",
    "release": "bash scripts/release.sh",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
