{
  "name": "promptpilot",
  "version": "0.1.0",
  "description": "AI-powered software planning pipeline — go from idea to complete specification suite in minutes",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/promptpilot/promptpilot"
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "promptpilot": "./bin/promptpilot.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf packages/*/dist packages/*/*.tsbuildinfo",
    "dev": "tsx watch packages/cli/src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "lint": "eslint 'packages/*/src/**/*.ts' --max-warnings 0",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --check 'packages/*/src/**/*.ts' '**/*.json' '**/*.md'",
    "format:fix": "prettier --write 'packages/*/src/**/*.ts' '**/*.json' '**/*.md'",
    "typecheck": "tsc -b --noEmit || tsc --noEmit -p tsconfig.json",
    "ci": "npm run lint && npm run format && npm run build && npm run test",
    "audit": "npm audit --audit-level=high",
    "release": "bash scripts/release.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
