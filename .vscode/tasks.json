{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: All Services",
      "type": "shell",
      "command": "pnpm dev",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Dev: Frontend",
      "type": "shell",
      "command": "pnpm dev:frontend",
      "problemMatcher": ["$tsc-watch"],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Dev: Backend",
      "type": "shell",
      "command": "pnpm dev:backend",
      "problemMatcher": ["$tsc-watch"],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "pnpm run build",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "TypeCheck",
      "type": "shell",
      "command": "pnpm run typecheck",
      "group": "test",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "pnpm run lint",
      "group": "test",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "Test: All",
      "type": "shell",
      "command": "pnpm run test",
      "group": "test"
    },
    {
      "label": "Test: Watch",
      "type": "shell",
      "command": "pnpm run test:watch",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Format",
      "type": "shell",
      "command": "pnpm run format",
      "problemMatcher": []
    },
    {
      "label": "Format: Fix",
      "type": "shell",
      "command": "pnpm run format:fix",
      "problemMatcher": []
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "pnpm run clean",
      "problemMatcher": []
    },
    {
      "label": "CI: Full Pipeline",
      "type": "shell",
      "command": "pnpm run ci",
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Docker: MongoDB",
      "type": "shell",
      "command": "docker compose -f docker/docker-compose.yml up -d mongodb",
      "problemMatcher": []
    }
  ]
}
