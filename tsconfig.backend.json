{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@promptpilot/shared": ["packages/shared/dist"],
      "@promptpilot/config": ["packages/config/dist"],
      "@promptpilot/db": ["packages/db/dist"],
      "@promptpilot/auth": ["packages/auth/dist"],
      "@promptpilot/core": ["packages/core/dist"],
      "@promptpilot/fs": ["packages/fs/dist"],
      "@promptpilot/validators": ["packages/validators/dist"],
      "@promptpilot/types": ["packages/types/dist"],
      "@promptpilot/validation": ["packages/validation/dist"]
    }
  }
}
