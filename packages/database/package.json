{
  "name": "@promptpilot/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma client, repositories, and migrations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client/index.js",
    "./repositories": "./dist/repositories/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "eslint src --ext ts,tsx --ignore-pattern '**/*.d.ts' --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../../prisma/schema.prisma",
    "db:seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@promptpilot/shared": "workspace:*",
    "@promptpilot/config": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  }
}
