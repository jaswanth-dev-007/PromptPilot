{
  "name": "@promptpilot/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript type definitions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api/index.js",
    "./database": "./dist/database/index.js",
    "./ai": "./dist/ai/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "eslint src --ext ts,tsx --ignore-pattern '**/*.d.ts' --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
