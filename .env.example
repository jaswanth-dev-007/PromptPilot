# =============================================================================
# PromptPilot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env files. They are in .gitignore.
# =============================================================================

# ---- Node Environment ----
NODE_ENV=development

# ---- Logging ----
LOG_LEVEL=info
# Options: trace, debug, info, warn, error, fatal

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3001
# Port for the Next.js dev server (default: 3000)

# ---- Backend (Express API) ----
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/promptpilot

# ---- PostgreSQL (Prisma) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promptpilot

# ---- Authentication (JWT) ----
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ---- LLM Providers (optional) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ---- Docker ----
# Used by docker compose for local development
COMPOSE_PROJECT_NAME=promptpilot
